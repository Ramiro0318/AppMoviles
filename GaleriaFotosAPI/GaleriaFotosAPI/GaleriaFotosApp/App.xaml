<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GaleriaFotosApp"
             x:Class="GaleriaFotosApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        
            <Color x:Key="Primary">#512BD4</Color>
            <Color x:Key="PrimaryDark">#3E1FA3</Color>
            <Color x:Key="Secondary">#DFD8F7</Color>
            <Color x:Key="White">#FFFFFF</Color>
            <Color x:Key="LightGray">#F5F5F5</Color>
            <Color x:Key="DarkGray">#666666</Color>
            <Color x:Key="Danger">#E53935</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
