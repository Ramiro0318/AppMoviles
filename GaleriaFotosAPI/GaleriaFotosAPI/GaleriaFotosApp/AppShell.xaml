<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GaleriaFotosApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GaleriaFotosMaui.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- Rutas sin Shell visibles (login/registro) -->
    <ShellContent
        x:Name="loginShell"
        Route="login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        x:Name="registroShell"
        Route="registro"
        ContentTemplate="{DataTemplate views:RegistroPage}"
        Shell.NavBarIsVisible="False" />

    <!-- TabBar principal (se muestra tras autenticación) -->
    <TabBar x:Name="mainTabs" Route="main">
        <ShellContent
            Title="Muro"
            Route="muro"
            Icon="photo_gallery.png"
            ContentTemplate="{DataTemplate views:MuroPage}" />
        <ShellContent
            Title="Subir"
            Route="subir"
            Icon="upload.png"
            ContentTemplate="{DataTemplate views:SubirFotoPage}" />
        <ShellContent
            Title="Perfil"
            Route="perfil"
            Icon="person.png"
            ContentTemplate="{DataTemplate views:PerfilPage}" />
    </TabBar>

</Shell>