<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GaleriaFotosMaui.Views.PerfilPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GaleriaFotosMaui.ViewModels"
    Title="Mi Perfil"
    BackgroundColor="{StaticResource White}">

    <VerticalStackLayout Padding="32" Spacing="20" VerticalOptions="Center">

        <Label Text="👤" FontSize="64" HorizontalOptions="Center" />

        <Label
            Text="{Binding PerfilNombreReal}"
            FontSize="24"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="{StaticResource Primary}" />

        <Label
            Text="{Binding PerfilNombreUsuario, StringFormat='@{0}'}"
            FontSize="16"
            HorizontalOptions="Center"
            TextColor="{StaticResource DarkGray}" />

        <BoxView HeightRequest="1" Color="{StaticResource LightGray}" Margin="0,8" />

        <Button
            Text="Cerrar Sesión"
            Command="{Binding CerrarSesionCommand}"
            BackgroundColor="{StaticResource Danger}"
            TextColor="White"
            CornerRadius="8"
            HeightRequest="48" />

    </VerticalStackLayout>
</ContentPage>