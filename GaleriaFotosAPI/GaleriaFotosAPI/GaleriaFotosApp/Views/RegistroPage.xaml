<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GaleriaFotosMaui.Views.RegistroPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GaleriaFotosMaui.ViewModels"
    Title="Registro"
    BackgroundColor="{StaticResource White}">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="16">

            <Label
                Text="Crear Cuenta"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="{StaticResource Primary}" />

            <Entry
                Placeholder="Nombre de usuario"
                Text="{Binding NombreUsuarioRegistro}"
                ReturnType="Next" />

            <Entry
                Placeholder="Nombre real"
                Text="{Binding NombreRealRegistro}"
                ReturnType="Next" />

            <Entry
                Placeholder="PIN (4-6 dígitos)"
                Text="{Binding PinRegistro}"
                IsPassword="True"
                Keyboard="Numeric"
                ReturnType="Done" />

            <Label
                Text="{Binding MensajeError}"
                TextColor="{StaticResource Danger}"
                FontSize="12" />

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource Primary}" />

            <Button
                Text="Registrarse"
                Command="{Binding RegistrarCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="48" />

            <Button
                Text="¿Ya tienes cuenta? Inicia sesión"
                Command="{Binding IrALoginCommand}"
                BackgroundColor="Transparent"
                TextColor="{StaticResource Primary}"
                BorderWidth="0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>