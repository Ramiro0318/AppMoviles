<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GaleriaFotosMaui.Views.MuroPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GaleriaFotosMaui.ViewModels"
    xmlns:models="clr-namespace:GaleriaFotosMaui.Models"
    Title="Muro"
    BackgroundColor="{StaticResource LightGray}">

    <Grid RowDefinitions="Auto,Auto,*">

        <Border
            Grid.Row="0"
            BackgroundColor="#FFF3CD"
            Stroke="#FFEEBA"
            Padding="12,8"
            Margin="8,8,8,0">
            <Label
                Text="{Binding Mensaje}"
                TextColor="#856404"
                FontSize="12"
                HorizontalOptions="Center" />

            <border.Style>
                <style targetType="border">
                    <Style.Triggers Binding="{Binding Mensaje}" Value="">
                        <Setter Property="IsVisible" value="False"></Setter>
                    <Style.Triggers/>
                </style>
            </border.Style>
        </Border>

        <ActivityIndicator
            Grid.Row="1"
            IsRunning="False"
            IsVisible="False"
            Color="{StaticResource Primary}"
            Margin="0,8" />

        <CollectionView ItemsSource="{Binding Fotos}"
            Grid.Row="2"
            Margin="8">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Margin="0,40">
                    <Label Text="📷" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="No hay fotos aún. ¡Sé el primero en subir una!" HorizontalOptions="Center" TextColor="{StaticResource DarkGray}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate >
                    <Border Margin="0,4" Padding="0" Shadow="True" BackgroundColor="White">
                        <Grid RowDefinitions="200,Auto">

                            <Image
                                Grid.Row="0"
                                Aspect="AspectFill"
                                HeightRequest="200" />

                            <Grid Grid.Row="1" Padding="12,8" ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="NombreUsuario" FontAttributes="Bold" FontSize="14" />
                                    <Label Text="dd/MM/yyyy" FontSize="11" TextColor="{StaticResource DarkGray}" />
                                </VerticalStackLayout>
                                <Button
                                    Grid.Column="1"
                                    Text="🗑️"
                                    BackgroundColor="{StaticResource Danger}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="36"
                                    WidthRequest="44"
                                    />
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>