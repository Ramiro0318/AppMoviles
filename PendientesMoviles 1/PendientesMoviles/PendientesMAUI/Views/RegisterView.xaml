<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PendientesMAUI.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Registro">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <Label
                Text="Crear cuenta"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label Text="Nombre de usuario" />
            <Entry x:Name="EntryUsuario" Text="{Binding NuevoUsuario.NombreUsuario}" Placeholder="Mínimo 3 caracteres" />

            <Label Text="Correo electrónico" />
            <Entry x:Name="EntryCorreo" Text="{Binding NuevoUsuario.Correo}" Placeholder="correo@ejemplo.com" Keyboard="Email" />

            <Label Text="Contraseña" />
            <Entry x:Name="EntryPassword" Text="{Binding NuevoUsuario.Contraseña}" Placeholder="Mínimo 6 caracteres" IsPassword="True" />


            <Button Text="Registrar" Command="{Binding RegisterCommand}" BackgroundColor="{StaticResource Primary}" />

            <Label HorizontalOptions="Center" Text="{Binding Errores}" TextColor="Red" FontSize="Small"></Label>
            
            <Label
                Text="¿Ya tienes cuenta? Inicia sesión"
                HorizontalOptions="Center"
                TextColor="Blue"
                TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GotoLoginCommand}"></TapGestureRecognizer>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>