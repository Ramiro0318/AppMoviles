<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PendientesMAUI.Views.TodoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:PendientesMAUI.ViewModels"
    xmlns:converters="clr-namespace:PendientesMAUI.Converters"
    Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"></converters:NullToBoolConverter>
    </ContentPage.Resources>
    <Grid RowDefinitions="Auto, *, Auto">
        <Label Grid.Row="0"
               Text="{Binding Usuario, StringFormat='Hola, {0}'}"
               FontSize="16"
               FontAttributes="Bold"
               Padding="16,12,16,0"
               HorizontalOptions="Start" />
        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Pendientes}"
            EmptyView="No hay pendientes. ¡Agrega uno!">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                        
                        <Grid
                            Padding="16,12"
                            ColumnDefinitions="Auto, *, Auto, auto"
                            ColumnSpacing="12">

                            <Button
                                Grid.Column="0"
                                Text="{Binding EstadoIcono}"
                                FontSize="22"
                                BackgroundColor="Transparent"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TodoViewModel}}, Path=ToggleEstadoCommand}"
                                CommandParameter="{Binding .}" />

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label
                                    Text="{Binding Titulo}"
                                    FontSize="16"
                                    FontAttributes="Bold" />
                                <Label
                                    Text="{Binding Descripcion}"
                                    FontSize="13"
                                    TextColor="Gray"
                                    IsVisible="{Binding Descripcion, Converter={StaticResource NullToBoolConverter}}" />
                                <Label
                                    Text="{Binding FechaCreacion, StringFormat='{0:dd/MM/yyyy}'}"
                                    FontSize="11"
                                    TextColor="LightGray" />
                            </VerticalStackLayout>

                            <Button
                                Grid.Column="2"
                                Text="✏️"
                                FontSize="18"
                                BackgroundColor="Transparent"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TodoViewModel}}, Path=GoToEditCommand}"
                                CommandParameter="{Binding .}" />
                        <Button Grid.Column="3"
        Text="⛔"
TextColor="Red" BackgroundColor="Transparent"        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TodoViewModel}}, Path=DeleteCommand}"
        CommandParameter="{Binding .}" />
                        </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator
            Grid.Row="1"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

        <Button
            Grid.Row="2"
            Text="+ Agregar Pendiente"
            Margin="16"
            Command="{Binding GoToAddCommand}" />

    </Grid>
</ContentPage>