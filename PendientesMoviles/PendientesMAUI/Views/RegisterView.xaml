<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PendientesMAUI.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Registro">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <Label
                Text="Crear cuenta"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label Text="Nombre de usuario" />
            <Entry x:Name="EntryUsuario" Placeholder="Mínimo 3 caracteres" />

            <Label Text="Correo electrónico" />
            <Entry x:Name="EntryCorreo" Placeholder="correo@ejemplo.com" Keyboard="Email" />

            <Label Text="Contraseña" />
            <Entry x:Name="EntryPassword" Placeholder="Mínimo 6 caracteres" IsPassword="True" />

            <Label Text="Confirmar contraseña" />
            <Entry x:Name="EntryConfirm" Placeholder="Repite la contraseña" IsPassword="True" />

            <Button Text="Registrar" IsEnabled="False" BackgroundColor="Gray" />

            <Label
                Text="¿Ya tienes cuenta? Inicia sesión"
                HorizontalOptions="Center"
                TextColor="Blue"
                TextDecorations="Underline" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>