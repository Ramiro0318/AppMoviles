<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PendientesMAUI.Views.LoginView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Iniciar Sesión">

    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

        <Label
            Text="Pendientes App"
            FontSize="28"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

        <Label Text="Usuario" />
        <Entry x:Name="EntryUsuario" Placeholder="Nombre de usuario" />

        <Label Text="Contraseña" />
        <Entry x:Name="EntryPassword" Placeholder="Contraseña" IsPassword="True" />

        <Button Text="Iniciar sesión" IsEnabled="False" BackgroundColor="Gray" />

        <Label
            Text="¿No tienes cuenta? Regístrate"
            HorizontalOptions="Center"
            TextColor="Blue"
            TextDecorations="Underline" >
            <Label.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding GotoRegistrarCommand}"></TapGestureRecognizer>
            </Label.GestureRecognizers>
        </Label>

    </VerticalStackLayout>
</ContentPage>